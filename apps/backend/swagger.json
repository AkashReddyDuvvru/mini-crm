{
  "openapi": "3.0.0",
  "info": {
    "title": "AI-Native Mini CRM API",
    "version": "1.0.0",
    "description": "API documentation for the CRM backend"
  },
  "servers": [
    {
      "url": "http://localhost:4000/api",
      "description": "Local server"
    }
  ],
  "paths": {
    "/customers": {
      "get": {
        "summary": "Get all customers",
        "responses": {
          "200": { "description": "A list of customers" }
        }
      }
    },
    "/campaigns": {
      "get": {
        "summary": "Get all campaigns",
        "responses": {
          "200": { "description": "A list of campaigns" }
        }
      },
      "post": {
        "summary": "Create a new campaign",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "segmentId": { "type": "string" },
                  "channel": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Campaign created" }
        }
      }
    },
    "/ai/segment": {
      "post": {
        "summary": "Generate segment filter from natural language",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Segment filter generated" }
        }
      }
    }
  }
}
