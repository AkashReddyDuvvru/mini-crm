// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  phone            String?
  age              Int?
  gender           String?
  city             String?
  signupDate       DateTime @default(now())
  totalSpend       Float    @default(0)
  lastPurchaseDate DateTime?

  orders           Order[]
  communications   Communication[]
}

model Order {
  id          String   @id @default(cuid())
  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String
  orderDate   DateTime @default(now())
  amount      Float
  category    String
  channel     String

  @@index([customerId])
}

model Segment {
  id          String   @id @default(cuid())
  name        String
  description String?
  queryFilter Json     // The structured filter generated by AI or visual builder
  prompt      String?  // The natural language prompt used to generate it (if any)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  segment     Segment  @relation(fields: [segmentId], references: [id])
  segmentId   String
  channel     String   // WhatsApp, SMS, Email, RCS
  message     String
  status      String   @default("Draft") // Draft, Review, Scheduled, Running, Completed
  schedule    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  communications Communication[]
}

model Communication {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  campaignId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String
  status      String   @default("Pending") // Pending, Sent, Delivered, Failed, Opened, Clicked, Converted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events      CommunicationEvent[]

  @@index([campaignId])
  @@index([customerId])
}

model CommunicationEvent {
  id              String         @id @default(cuid())
  communication   Communication  @relation(fields: [communicationId], references: [id])
  communicationId String
  status          String         // Delivered, Failed, Opened, Clicked, Converted
  rawPayload      Json?
  createdAt       DateTime       @default(now())

  @@index([communicationId])
}

model AIInteraction {
  id        String   @id @default(cuid())
  prompt    String
  response  String
  action    String?  // Action taken by the agent (e.g., query, create_segment, launch_campaign)
  createdAt DateTime @default(now())
}
